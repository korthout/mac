#!/bin/bash

if [ "$#" -eq "0" ]; then
	echo "Uninstalls a package using brew bundle"
	echo ""
	echo "Usage: brew-uninstall <package>"
	echo ""
	echo "Note that this tool may uninstall other packages when syncing Brewfile"
	exit 0
fi

set -ex

package=$1

function config() {
	git --git-dir=$HOME/.cfg/ --work-tree=$HOME $@
}

# Make sure foreground process group can be terminated
trap 'echo Terminated $0; exit' INT

# Make sure all recent Brewfile changes are installed
config pull

brew uninstall "$package"
brew bundle remove --global "$package"

config add $XDG_CONFIG_HOME/homebrew/Brewfile
config commit -m "Uninstall-$package"
config push
