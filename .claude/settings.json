{
  "permissions": {
    "allow": [
      "Bash(curl -s \"https://api.github.com/repos/camunda/camunda/actions/*)",
      "Bash(curl -s \"https://api.github.com/repos/camunda/camunda/issues/*)",
      "Bash(curl -s \"https://api.github.com/repos/camunda/camunda/pulls/*)",
      "Bash(curl -s \"https://api.github.com/search/issues?q*)",
      "Bash(gh issue *)",
      "Bash(gh search *)",
      "Bash(git -C * add *)",
      "Bash(git -C * branch *)",
      "Bash(git -C * commit *)",
      "Bash(git -C * describe *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * log *)",
      "Bash(git -C * ls-files *)",
      "Bash(git -C * remote *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git -C * show *)",
      "Bash(git -C * stash *)",
      "Bash(git -C * status *)",
      "Bash(git -C * tag *)",
      "Bash(git -C * worktree *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(mvn compile *)",
      "Bash(mvn install *)",
      "Bash(mvn license:format *)",
      "Bash(mvn spotless:apply *)",
      "Bash(mvn test *)",
      "Bash(mvn test-compile *)",
      "Bash(mvn verify *)",
      "Bash(rtk diff *)",
      "Bash(rtk find *)",
      "Bash(rtk gh *)",
      "Bash(rtk git *)",
      "Bash(rtk grep *)",
      "Bash(rtk json *)",
      "Bash(rtk log *)",
      "Bash(rtk ls *)",
      "Bash(rtk read *)",
      "Bash(rtk rg *)",
      "Bash(rtk tree *)",
      "mcp__claude_ai_Glean__search",
      "mcp__claude_ai_Glean__read_document"
    ],
    "defaultMode": "default"
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/commit-title-check.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/worktree-create.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'cols=${COLUMNS:-}; case \"$cols\" in \"\"|*[!0-9]*) cols=$(stty size </dev/tty 2>/dev/null | awk '\"'\"'{print $2}'\"'\"');; esac; case \"$cols\" in \"\"|*[!0-9]*) cols=120;; esac; export COLUMNS=$(( cols > 4 ? cols - 4 : 1 )); plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/*/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $0 }'\"'\"' | grep -E '\"'\"'^[0-9]+\\.[0-9]+\\.[0-9]+[[:space:]]'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"/opt/homebrew/bin/node\" \"${plugin_dir}dist/index.js\"'"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "superpowers@claude-plugins-official": false,
    "crit@crit": true,
    "eng-kit@camunda-internal": true,
    "check-architecture-principles@actora": true,
    "check-camunda-docs@actora": true,
    "create-architecture-decision@actora": true,
    "product-sense-review@actora": true,
    "write-camunda-docs@actora": true,
    "generate-deck@actora": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    },
    "camunda-internal": {
      "source": {
        "source": "github",
        "repo": "camunda/claude-marketplace-internal"
      }
    },
    "actora": {
      "source": {
        "source": "github",
        "repo": "camunda/actora"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowUnixSockets": [
        "$HOME/.gnupg/S.gpg-agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "$HOME/.gnupg"
      ]
    }
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "advisorModel": "opus",
  "theme": "light",
  "skipAutoPermissionPrompt": true
}
